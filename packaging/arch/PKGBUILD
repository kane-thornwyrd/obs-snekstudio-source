_pkgbuild_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

pkgname=obs-snekstudio-source
pkgver=0.1.0
pkgrel=1
pkgdesc="OBS Studio plugin and demo publisher for cooperative SnekStudio capture"
arch=('x86_64')
url='https://github.com/kane-thornwyrd/obs-snekstudio-source'
license=('GPL-3.0-or-later')
depends=('obs-studio' 'python')
makedepends=('cmake' 'pkgconf')
install='obs-snekstudio-source.install'
source=("${pkgname}-${pkgver}.tar.gz::file://${_pkgbuild_dir}/../../dist/${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
	rm -rf build
	cmake -S "${srcdir}/${pkgname}-${pkgver}" \
		-B build \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="${pkgdir}" cmake --install build
}