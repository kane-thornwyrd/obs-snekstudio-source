post_install() {
	cat <<'EOF'
SnekStudio Source installed for OBS.

Quick smoke test:
  1. Start the demo publisher: snekstudio-demo-publisher
  2. Open OBS and add the input source: SnekStudio Source (MVP)
  3. Open source properties if you want to inspect the built-in status panel

To use this with the real application, replace the demo publisher with a
SnekStudio-side producer that writes the shared frame protocol.
EOF
}

post_upgrade() {
	post_install
}